---
import Icon from '@/components/ui/Icon.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
---

<section class="ba section" id="resultados" data-reveal>
  <div class="container">
    <SectionHeading
      label="Resultados Reais"
      title="Veja a diferença que o seu negócio faz no Google"
      subtitle="Arraste a divisória e compare antes vs depois — esse é o impacto que entregamos para nossos clientes."
      highlight="diferença"
    />

    <!-- Slider comparativo -->
    <div class="ba__slider" data-ba>
      <div class="ba__pane ba__pane--after">
        <div class="ba__pane-tag ba__pane-tag--after">
          <Icon name="check-circle" size={14} /> Depois
        </div>
        <div class="ba__google">
          <div class="ba__google-bar">
            <Icon name="search" size={14} />
            <span>salão de beleza barueri</span>
          </div>
          <div class="ba__google-tabs">
            <span class="ba__google-tab ba__google-tab--active">Tudo</span>
            <span class="ba__google-tab">Maps</span>
            <span class="ba__google-tab">Imagens</span>
            <span class="ba__google-tab">Notícias</span>
          </div>
          <div class="ba__featured">
            <div class="ba__featured-tag">
              <Icon name="sparkles" size={11} /> Resultado em destaque
            </div>
            <div class="ba__featured-head">
              <div class="ba__featured-avatar">MB</div>
              <div>
                <div class="ba__featured-title">Márcia Beauty — Salão Premium</div>
                <div class="ba__featured-url">marciabeauty.com.br</div>
              </div>
            </div>
            <div class="ba__featured-desc">Salão completo em Barueri. Corte, coloração, manicure...</div>
            <div class="ba__featured-meta">
              <span class="ba__rating">★★★★★ 4.9</span>
              <span>· 142 avaliações</span>
              <span>· Aberto agora</span>
            </div>
          </div>
          <div class="ba__google-result">
            <span class="ba__google-result-title">Salão Beleza & Cia — Centro</span>
            <span class="ba__google-result-url">salaobeleza.com.br</span>
          </div>
          <div class="ba__google-result">
            <span class="ba__google-result-title">Studio Hair Premium — Alphaville</span>
            <span class="ba__google-result-url">studiohairpremium.com</span>
          </div>
        </div>
      </div>

      <div class="ba__pane ba__pane--before" data-ba-before>
        <div class="ba__pane-tag ba__pane-tag--before">
          <Icon name="x-circle" size={14} /> Antes
        </div>
        <div class="ba__google">
          <div class="ba__google-bar">
            <Icon name="search" size={14} />
            <span>salão de beleza barueri</span>
          </div>
          <div class="ba__google-tabs">
            <span class="ba__google-tab ba__google-tab--active">Tudo</span>
            <span class="ba__google-tab">Maps</span>
            <span class="ba__google-tab">Imagens</span>
            <span class="ba__google-tab">Notícias</span>
          </div>
          <div class="ba__google-result">
            <span class="ba__google-result-title">Salão Beleza & Cia — Centro</span>
            <span class="ba__google-result-url">salaobeleza.com.br</span>
          </div>
          <div class="ba__google-result">
            <span class="ba__google-result-title">Studio Hair Premium — Alphaville</span>
            <span class="ba__google-result-url">studiohairpremium.com</span>
          </div>
          <div class="ba__google-result">
            <span class="ba__google-result-title">Beleza Express — Osasco</span>
            <span class="ba__google-result-url">belezaexpress.com.br</span>
          </div>
          <div class="ba__missing">
            <Icon name="search-x" size={28} />
            <strong>Seu negócio não aparece nos resultados</strong>
          </div>
        </div>
      </div>

      <div class="ba__handle" data-ba-handle aria-hidden="true">
        <span class="ba__handle-bar"></span>
        <span class="ba__handle-knob">
          <Icon name="arrow-right" size={14} />
          <Icon name="arrow-right" size={14} class="ba__handle-knob-flip" />
        </span>
      </div>
    </div>

    <p class="ba__hint">
      <Icon name="sparkles" size={14} />
      <span>Arraste para comparar — funciona com mouse ou toque</span>
    </p>
  </div>
</section>

<script>
  function initBA() {
    const sliders = document.querySelectorAll<HTMLElement>('[data-ba]');
    sliders.forEach((slider) => {
      const before = slider.querySelector<HTMLElement>('[data-ba-before]');
      const handle = slider.querySelector<HTMLElement>('[data-ba-handle]');
      if (!before || !handle) return;

      let dragging = false;

      const setPos = (xPct: number) => {
        const clamped = Math.max(0, Math.min(100, xPct));
        before.style.clipPath = `inset(0 ${100 - clamped}% 0 0)`;
        handle.style.left = `${clamped}%`;
      };

      const onMove = (clientX: number) => {
        const rect = slider.getBoundingClientRect();
        const pct = ((clientX - rect.left) / rect.width) * 100;
        setPos(pct);
      };

      handle.addEventListener('pointerdown', (e) => {
        dragging = true;
        handle.setPointerCapture(e.pointerId);
        slider.classList.add('ba__slider--dragging');
      });
      handle.addEventListener('pointerup', (e) => {
        dragging = false;
        handle.releasePointerCapture(e.pointerId);
        slider.classList.remove('ba__slider--dragging');
      });
      handle.addEventListener('pointermove', (e) => {
        if (!dragging) return;
        onMove(e.clientX);
      });

      slider.addEventListener('click', (e) => {
        if (e.target === handle || handle.contains(e.target as Node)) return;
        onMove(e.clientX);
      });

      // Initial position
      setPos(50);

      // Auto demo on scroll
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            let p = 50;
            const step = (t: number) => {
              p = 50 + Math.sin(t / 600) * 35;
              setPos(p);
              if (t < 2400) requestAnimationFrame(step);
              else setPos(50);
            };
            requestAnimationFrame(step);
            io.unobserve(slider);
          }
        });
      }, { threshold: 0.5 });
      io.observe(slider);
    });
  }
  initBA();
</script>

<style>
  .ba { background: var(--bg-alt); }

  .ba__slider {
    position: relative;
    margin: 56px auto 0;
    max-width: 920px;
    /* Altura mínima garante espaço para o conteúdo dos painéis em qualquer largura */
    min-height: 540px;
    background: var(--bg-white);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    user-select: none;
    cursor: ew-resize;
  }
  @media (min-width: 640px) {
    .ba__slider { min-height: 520px; aspect-ratio: 16 / 11; }
  }
  @media (min-width: 1024px) {
    .ba__slider { aspect-ratio: 16 / 9; min-height: 0; }
  }

  .ba__pane {
    position: absolute;
    inset: 0;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .ba__pane--after {
    background:
      radial-gradient(circle at 30% 0%, rgba(34, 197, 94, 0.06) 0%, transparent 50%),
      var(--bg-white);
  }
  .ba__pane--before {
    clip-path: inset(0 50% 0 0);
    background:
      radial-gradient(circle at 30% 0%, rgba(239, 68, 68, 0.06) 0%, transparent 50%),
      #FFF8F8;
    z-index: 2;
  }
  .ba__slider--dragging .ba__pane--before { transition: none; }

  .ba__pane-tag {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .ba__pane-tag--after {
    background: rgba(34, 197, 94, 0.12);
    color: #15803D;
  }
  .ba__pane-tag--before {
    background: rgba(239, 68, 68, 0.12);
    color: #DC2626;
  }

  .ba__google {
    flex: 1;
    background: var(--bg-white);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    overflow: hidden;
  }
  .ba__google-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    background: var(--bg-alt);
    border-radius: var(--radius-full);
    font-size: 12.5px;
    color: var(--text-secondary);
  }
  .ba__google-bar :global(svg) { color: var(--text-muted); }

  .ba__google-tabs {
    display: flex;
    gap: 14px;
    border-bottom: 1px solid var(--border-soft);
    padding-bottom: 8px;
  }
  .ba__google-tab {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 500;
    padding-bottom: 4px;
  }
  .ba__google-tab--active {
    color: var(--primary);
    border-bottom: 2px solid var(--accent);
    font-weight: 600;
  }

  .ba__featured {
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.08) 0%, transparent 70%);
    border: 1.5px solid rgba(34, 197, 94, 0.35);
    border-radius: var(--radius-md);
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    box-shadow: 0 6px 20px rgba(34, 197, 94, 0.12);
  }
  .ba__featured-tag {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    font-weight: 700;
    color: #15803D;
    background: rgba(34, 197, 94, 0.18);
    padding: 3px 8px;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .ba__featured-head {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ba__featured-avatar {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: var(--grad-accent);
    color: #FFFFFF;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ba__featured-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
  }
  .ba__featured-url {
    font-size: 11px;
    color: #15803D;
  }
  .ba__featured-desc {
    font-size: 12px;
    color: var(--text-secondary);
    line-height: 1.4;
  }
  .ba__featured-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 11px;
    color: var(--text-muted);
  }
  .ba__rating { color: #F59E0B; font-weight: 600; }

  .ba__google-result {
    padding: 10px 12px;
    border-radius: var(--radius-sm);
    background: var(--bg-alt);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .ba__google-result-title {
    font-size: 12.5px;
    color: #1D4ED8;
    font-weight: 500;
  }
  .ba__google-result-url {
    font-size: 11px;
    color: var(--text-muted);
  }

  .ba__missing {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px;
    background: rgba(239, 68, 68, 0.08);
    border: 1.5px dashed rgba(239, 68, 68, 0.4);
    border-radius: var(--radius-md);
    color: #DC2626;
    font-size: 13px;
  }
  .ba__missing strong { font-weight: 600; }

  /* Handle */
  .ba__handle {
    position: absolute;
    top: 0; bottom: 0;
    left: 50%;
    width: 2px;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.1), 0 0 20px rgba(15, 23, 42, 0.2);
    z-index: 3;
    cursor: ew-resize;
    touch-action: none;
  }
  .ba__handle-knob {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 48px; height: 48px;
    border-radius: 50%;
    background: var(--grad-accent);
    color: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(255, 107, 53, 0.4);
    border: 2.5px solid #FFFFFF;
    transition: transform 0.3s var(--ease-out-back);
  }
  .ba__handle:hover .ba__handle-knob,
  .ba__slider--dragging .ba__handle-knob {
    transform: translate(-50%, -50%) scale(1.12);
  }
  .ba__handle-knob :global(.ba__handle-knob-flip) {
    transform: rotate(180deg);
  }

  .ba__hint {
    margin: 24px auto 0;
    text-align: center;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    justify-content: center;
    font-size: 13px;
    color: var(--text-muted);
  }
  .ba__hint :global(svg) { color: var(--accent); }
</style>
