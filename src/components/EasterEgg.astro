---
import Icon from '@/components/ui/Icon.astro';
import { WHATSAPP_NUMBER } from '@/data/config';

const couponCode = 'TREVIZZO10';
const discount = '10% OFF';
---

<!-- Hint discreta -->
<div class="egg-hint" aria-hidden="true">
  <span class="egg-hint__key">?</span>
  <span class="egg-hint__tip">Psiu… tem um cupom secreto escondido nesta página. <br />Dica: digite o nome da gente.</span>
</div>

<!-- Modal do cupom (aparece ao descobrir) -->
<div class="egg-modal" id="egg-modal" role="dialog" aria-modal="true" aria-labelledby="egg-title" hidden>
  <div class="egg-backdrop" id="egg-close-bg"></div>

  <!-- Confetti canvas -->
  <canvas class="egg-confetti" id="egg-confetti" aria-hidden="true"></canvas>

  <div class="egg-card">
    <button class="egg-close" id="egg-close" aria-label="Fechar">
      <Icon name="x" size={18} />
    </button>

    <div class="egg-sparkle egg-sparkle--1" aria-hidden="true">✨</div>
    <div class="egg-sparkle egg-sparkle--2" aria-hidden="true">🎉</div>
    <div class="egg-sparkle egg-sparkle--3" aria-hidden="true">🎁</div>

    <div class="egg-ribbon">
      <Icon name="sparkles" size={12} />
      Código secreto desbloqueado
    </div>

    <h2 id="egg-title" class="egg-title">
      Você achou! <br />
      <span class="egg-title-accent">{discount}</span> no seu pacote
    </h2>

    <p class="egg-desc">
      Parabéns pela curiosidade 👀. Use esse cupom quando fechar conosco no WhatsApp — é válido por 48h a partir de agora.
    </p>

    <div class="egg-coupon" id="egg-coupon">
      <span class="egg-coupon-label">Seu cupom</span>
      <div class="egg-coupon-body">
        <code id="egg-code">{couponCode}</code>
        <button class="egg-coupon-copy" id="egg-coupon-copy" type="button">
          <Icon name="check-circle" size={14} />
          <span>Copiar</span>
        </button>
      </div>
    </div>

    <a
      class="egg-cta"
      id="egg-cta"
      href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent('Olá! Achei o cupom secreto no site 🎉 Quero usar o ' + couponCode + ' no meu pacote.')}`}
      target="_blank"
      rel="noopener noreferrer"
    >
      <Icon name="message-circle" size={16} />
      Resgatar no WhatsApp
    </a>

    <p class="egg-fine">Válido 48h · Não acumulável · Pacote anual</p>
  </div>
</div>

<script define:vars={{ COUPON: couponCode }}>
  const modal = document.getElementById('egg-modal');
  const closeBtn = document.getElementById('egg-close');
  const closeBg = document.getElementById('egg-close-bg');
  const copyBtn = document.getElementById('egg-coupon-copy');
  const canvas = document.getElementById('egg-confetti');
  const hint = document.querySelector('.egg-hint');

  const STORAGE_KEY = 'trevizzo:egg-unlocked';
  const HINT_KEY = 'trevizzo:egg-hint-seen';

  // Mostra a dica sutil após 45s na página, só uma vez
  setTimeout(() => {
    if (sessionStorage.getItem(HINT_KEY)) return;
    if (localStorage.getItem(STORAGE_KEY)) return;
    hint?.classList.add('is-visible');
    sessionStorage.setItem(HINT_KEY, '1');
    setTimeout(() => hint?.classList.remove('is-visible'), 9000);
  }, 45000);

  hint?.addEventListener('click', () => hint?.classList.remove('is-visible'));

  // Detector de palavra-chave: "trevizzo" digitado em qualquer lugar
  const target = 'trevizzo';
  let buffer = '';
  window.addEventListener('keydown', (e) => {
    // ignora teclas modificadoras / navegação
    if (e.ctrlKey || e.metaKey || e.altKey) return;
    if (e.key.length !== 1) return;
    // não dispara se estiver digitando num campo
    const tag = (e.target?.tagName || '').toLowerCase();
    if (tag === 'input' || tag === 'textarea' || e.target?.isContentEditable) return;
    buffer = (buffer + e.key.toLowerCase()).slice(-target.length);
    if (buffer === target) {
      unlock();
    }
  });

  // Konami code alternativo: ↑ ↑ ↓ ↓ ← → ← → B A
  const konami = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
  let kIdx = 0;
  window.addEventListener('keydown', (e) => {
    const k = e.key.length === 1 ? e.key.toLowerCase() : e.key;
    if (k === konami[kIdx]) {
      kIdx++;
      if (kIdx === konami.length) { kIdx = 0; unlock(); }
    } else {
      kIdx = (k === konami[0]) ? 1 : 0;
    }
  });

  function unlock() {
    if (!modal || modal.dataset.open === '1') return;
    modal.removeAttribute('hidden');
    requestAnimationFrame(() => modal.classList.add('is-open'));
    modal.dataset.open = '1';
    localStorage.setItem(STORAGE_KEY, '1');
    hint?.classList.remove('is-visible');
    fireConfetti();
    document.body.style.overflow = 'hidden';
  }

  function close() {
    if (!modal) return;
    modal.classList.remove('is-open');
    modal.dataset.open = '0';
    setTimeout(() => modal.setAttribute('hidden', ''), 320);
    document.body.style.overflow = '';
  }

  closeBtn?.addEventListener('click', close);
  closeBg?.addEventListener('click', close);
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal?.dataset.open === '1') close(); });

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(COUPON);
      const label = copyBtn.querySelector('span');
      if (label) {
        const prev = label.textContent;
        label.textContent = 'Copiado!';
        copyBtn.classList.add('is-ok');
        setTimeout(() => {
          label.textContent = prev;
          copyBtn.classList.remove('is-ok');
        }, 1800);
      }
    } catch (err) {
      /* fallback silencioso */
    }
  });

  // ========== CONFETTI ==========
  function fireConfetti() {
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const dpr = Math.min(2, window.devicePixelRatio || 1);
    const w = canvas.clientWidth = window.innerWidth;
    const h = canvas.clientHeight = window.innerHeight;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx.scale(dpr, dpr);

    const colors = ['#FF6B35', '#FFB199', '#2E5A8F', '#FFFFFF', '#FFD700', '#4ADE80'];
    const particles = [];
    const count = 140;
    for (let i = 0; i < count; i++) {
      particles.push({
        x: w / 2 + (Math.random() - 0.5) * 120,
        y: h / 2 + (Math.random() - 0.5) * 40,
        vx: (Math.random() - 0.5) * 16,
        vy: (Math.random() - 0.8) * 18,
        g: 0.45 + Math.random() * 0.25,
        size: 6 + Math.random() * 6,
        color: colors[Math.floor(Math.random() * colors.length)],
        rot: Math.random() * Math.PI,
        vr: (Math.random() - 0.5) * 0.3,
        life: 1,
        shape: Math.random() > 0.5 ? 'rect' : 'circ',
      });
    }

    let running = true;
    const start = performance.now();
    function frame(now) {
      if (!running) return;
      const elapsed = now - start;
      ctx.clearRect(0, 0, w, h);
      particles.forEach((p) => {
        p.vy += p.g;
        p.x += p.vx;
        p.y += p.vy;
        p.rot += p.vr;
        p.life = Math.max(0, 1 - elapsed / 3200);
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot);
        ctx.globalAlpha = p.life;
        ctx.fillStyle = p.color;
        if (p.shape === 'rect') {
          ctx.fillRect(-p.size / 2, -p.size / 3, p.size, p.size / 1.6);
        } else {
          ctx.beginPath();
          ctx.arc(0, 0, p.size / 2, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.restore();
      });
      if (elapsed < 3400) {
        requestAnimationFrame(frame);
      } else {
        ctx.clearRect(0, 0, w, h);
        running = false;
      }
    }
    requestAnimationFrame(frame);
  }
</script>

<style>
  /* ===== Dica discreta ===== */
  .egg-hint {
    position: fixed;
    bottom: 104px;
    right: 24px;
    z-index: 85;
    display: flex;
    align-items: flex-end;
    gap: 10px;
    max-width: 280px;
    opacity: 0;
    transform: translateY(16px) scale(0.96);
    pointer-events: none;
    transition: opacity 0.5s var(--ease-out-expo), transform 0.5s var(--ease-out-expo);
  }
  .egg-hint.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
    cursor: pointer;
  }
  .egg-hint__key {
    width: 32px; height: 32px;
    display: grid; place-items: center;
    background: var(--grad-accent);
    border-radius: 50%;
    font-size: 16px;
    font-weight: 800;
    color: #FFFFFF;
    box-shadow: 0 6px 18px rgba(255, 107, 53, 0.4);
    animation: egg-bob 2.2s ease-in-out infinite;
    flex-shrink: 0;
  }
  .egg-hint__tip {
    background: rgba(15, 23, 42, 0.95);
    color: #F1F5F9;
    padding: 10px 14px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 12.5px;
    line-height: 1.45;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
  }
  @keyframes egg-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  /* ===== Modal ===== */
  .egg-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
    padding: 20px;
    opacity: 0;
    transition: opacity 0.3s var(--ease-out-expo);
  }
  .egg-modal.is-open { opacity: 1; }
  .egg-backdrop {
    position: absolute; inset: 0;
    background: rgba(6, 11, 23, 0.78);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .egg-confetti {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 201;
  }

  .egg-card {
    position: relative;
    z-index: 202;
    width: 100%;
    max-width: 440px;
    padding: 36px 28px 28px;
    background:
      radial-gradient(circle at top right, rgba(255,107,53,0.22) 0%, transparent 55%),
      linear-gradient(180deg, #1A2D4A 0%, #0F1B30 100%);
    border: 1px solid rgba(255, 107, 53, 0.35);
    border-radius: var(--radius-2xl);
    box-shadow:
      0 40px 100px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.06) inset,
      0 0 60px rgba(255, 107, 53, 0.25);
    color: #FFFFFF;
    text-align: center;
    transform: scale(0.9) translateY(30px);
    transition: transform 0.4s var(--ease-out-back);
  }
  .egg-modal.is-open .egg-card { transform: scale(1) translateY(0); }

  .egg-close {
    position: absolute;
    top: 12px; right: 12px;
    width: 32px; height: 32px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    color: #CBD5E1;
    display: grid;
    place-items: center;
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }
  .egg-close:hover { background: rgba(255, 255, 255, 0.16); color: #FFFFFF; transform: rotate(90deg); }

  .egg-sparkle {
    position: absolute;
    font-size: 22px;
    animation: egg-float 3s ease-in-out infinite;
    pointer-events: none;
  }
  .egg-sparkle--1 { top: -10px; left: 24px; animation-delay: 0s; }
  .egg-sparkle--2 { top: 18px; right: -8px; animation-delay: 0.6s; font-size: 28px; }
  .egg-sparkle--3 { top: 70px; left: -12px; animation-delay: 1.2s; }
  @keyframes egg-float {
    0%, 100% { transform: translateY(0) rotate(-5deg); opacity: 0.8; }
    50% { transform: translateY(-8px) rotate(8deg); opacity: 1; }
  }

  .egg-ribbon {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: rgba(255, 107, 53, 0.15);
    border: 1px solid rgba(255, 107, 53, 0.35);
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }

  .egg-title {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 12px;
  }
  .egg-title-accent {
    background: var(--grad-text-accent);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    font-size: 36px;
  }
  .egg-desc {
    font-size: 14px;
    color: #CBD5E1;
    line-height: 1.55;
    margin-bottom: 22px;
  }

  .egg-coupon {
    padding: 14px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px dashed rgba(255, 107, 53, 0.45);
    border-radius: var(--radius-lg);
    margin-bottom: 18px;
  }
  .egg-coupon-label {
    display: block;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #94A3B8;
    margin-bottom: 8px;
  }
  .egg-coupon-body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .egg-coupon code {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 800;
    letter-spacing: 0.15em;
    color: #FFFFFF;
    background: linear-gradient(120deg, #FFF 0%, #FFB199 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .egg-coupon-copy {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: var(--radius-full);
    font-size: 12.5px;
    font-weight: 600;
    color: #FFFFFF;
    transition: background 0.2s, transform 0.2s;
  }
  .egg-coupon-copy:hover { background: rgba(255, 255, 255, 0.14); transform: translateY(-1px); }
  .egg-coupon-copy.is-ok {
    background: rgba(34, 197, 94, 0.2);
    border-color: rgba(34, 197, 94, 0.5);
    color: #4ADE80;
  }
  .egg-coupon-copy :global(svg) { opacity: 0.8; }

  .egg-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px 20px;
    background: var(--grad-accent);
    color: #FFFFFF;
    border-radius: var(--radius-full);
    font-size: 14.5px;
    font-weight: 700;
    box-shadow: 0 12px 28px rgba(255, 107, 53, 0.4);
    transition: transform 0.25s var(--ease-out-back), box-shadow 0.25s;
    text-decoration: none;
  }
  .egg-cta:hover { transform: translateY(-2px); box-shadow: 0 16px 36px rgba(255, 107, 53, 0.5); }

  .egg-fine {
    margin-top: 12px;
    font-size: 10.5px;
    color: #64748B;
    letter-spacing: 0.05em;
  }

  @media (max-width: 520px) {
    .egg-hint { bottom: 96px; right: 16px; max-width: 240px; }
    .egg-title { font-size: 24px; }
    .egg-title-accent { font-size: 30px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .egg-sparkle, .egg-hint__key { animation: none; }
  }
</style>
