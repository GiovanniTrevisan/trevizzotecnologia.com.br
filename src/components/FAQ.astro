---
import Icon from '@/components/ui/Icon.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Button from '@/components/ui/Button.astro';
import { faqItems } from '@/data/faq';
import { WHATSAPP_URL } from '@/data/config';
---

<section class="faq section" id="faq" data-reveal>
  <div class="container">
    <SectionHeading
      label="Perguntas Frequentes"
      title="Toda dúvida tem resposta. Aqui estão as principais."
      subtitle="Não achou o que procurava? Chama a gente no WhatsApp — respondemos em minutos."
      highlight="resposta"
    />

    <div class="faq__layout">
      <div class="faq__list">
        {faqItems.map((item, i) => (
          <details class:list={['faq__item', { 'faq__item--open': i === 0 }]} open={i === 0}>
            <summary class="faq__question">
              <div class="faq__question-text">
                {item.category && <span class="faq__cat">{item.category}</span>}
                <span class="faq__q-text">{item.question}</span>
              </div>
              <span class="faq__chevron">
                <Icon name="plus" size={18} class="faq__chevron-plus" />
                <Icon name="minus" size={18} class="faq__chevron-minus" />
              </span>
            </summary>
            <div class="faq__answer">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </div>

      <aside class="faq__aside">
        <div class="faq__aside-inner">
          <div class="faq__aside-icon">
            <Icon name="message-circle" size={22} />
          </div>
          <h3>Ainda em dúvida?</h3>
          <p>
            Falar com um humano resolve em 5 minutos o que pesquisar leva uma hora.
            Sem script, sem pressão de venda — só uma conversa.
          </p>
          <Button href={WHATSAPP_URL} variant="primary" size="lg" fullWidth dataCta="faq-whats" target="_blank" rel="noopener noreferrer">
            <Icon name="whatsapp" size={16} />
            Falar pelo WhatsApp
          </Button>
          <Button href="#orcamento" variant="ghost" size="md" fullWidth dataCta="faq-form">
            Pedir orçamento por formulário
          </Button>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .faq { background: var(--bg-white); }

  .faq__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    margin-top: 48px;
  }
  @media (min-width: 900px) {
    .faq__layout {
      grid-template-columns: 1.7fr 1fr;
      gap: 32px;
      align-items: start;
    }
  }
  @media (min-width: 1200px) {
    .faq__layout { gap: 40px; }
  }

  .faq__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .faq__item {
    background: var(--bg-white);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    transition: border-color 0.4s, box-shadow 0.4s;
  }
  .faq__item:hover { border-color: var(--border-medium); }
  .faq__item[open] {
    border-color: rgba(255, 107, 53, 0.3);
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
  }

  .faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 20px;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .faq__question::-webkit-details-marker { display: none; }
  .faq__question-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .faq__cat {
    font-size: 10.5px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .faq__q-text {
    font-size: 15.5px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
  }
  @media (min-width: 768px) {
    .faq__q-text { font-size: 16.5px; }
    .faq__question { padding: 22px 26px; }
  }

  .faq__chevron {
    flex-shrink: 0;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--bg-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    transition: background 0.3s, color 0.3s, transform 0.4s var(--ease-out-back);
    position: relative;
  }
  .faq__item[open] .faq__chevron {
    background: var(--grad-accent);
    color: #FFFFFF;
    transform: rotate(180deg);
  }
  .faq__chevron :global(.faq__chevron-plus),
  .faq__chevron :global(.faq__chevron-minus) {
    position: absolute;
    inset: 0;
    margin: auto;
    transition: opacity 0.3s, transform 0.3s;
  }
  .faq__chevron :global(.faq__chevron-minus) { opacity: 0; transform: rotate(-180deg); }
  .faq__item[open] .faq__chevron :global(.faq__chevron-plus)  { opacity: 0; transform: rotate(180deg); }
  .faq__item[open] .faq__chevron :global(.faq__chevron-minus) { opacity: 1; transform: rotate(0deg); }

  .faq__answer {
    padding: 0 20px 20px;
    animation: faq-open 0.45s var(--ease-out-expo);
  }
  @media (min-width: 768px) {
    .faq__answer { padding: 0 26px 24px; }
  }
  .faq__answer p {
    font-size: 14.5px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 680px;
  }
  @keyframes faq-open {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Aside CTA */
  .faq__aside {
    position: sticky;
    top: 100px;
  }
  .faq__aside-inner {
    background: linear-gradient(160deg, var(--primary) 0%, var(--bg-dark) 100%);
    border-radius: var(--radius-xl);
    padding: 28px;
    color: #FFFFFF;
    display: flex;
    flex-direction: column;
    gap: 14px;
    box-shadow: var(--shadow-lg);
    position: relative;
    overflow: hidden;
  }
  .faq__aside-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 100% 0%, rgba(255,107,53,0.18), transparent 50%);
    pointer-events: none;
  }
  .faq__aside-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    background: rgba(255, 107, 53, 0.18);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }
  .faq__aside-inner h3 {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    position: relative;
    z-index: 1;
  }
  .faq__aside-inner p {
    font-size: 14px;
    color: #CBD5E1;
    line-height: 1.6;
    position: relative;
    z-index: 1;
  }

  .faq__aside-inner :global(.btn--ghost) {
    --btn-color: #FFFFFF;
    border-color: #FFFFFF;
  }
  .faq__aside-inner :global(.btn--ghost:hover) {
    background: rgba(255, 255, 255, 0.1);
    border-color: #FFFFFF;
    color: #FFFFFF;
  }
</style>
