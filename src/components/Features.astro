---
import Icon from '@/components/ui/Icon.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { features } from '@/data/features';
---

<section class="features section" data-reveal>
  <div class="container">
    <SectionHeading label="O QUE ESTÁ INCLUÍDO" title="Tudo o que você precisa. Sem surpresas." />

    <div class="features__grid">
      {features.map((f) => (
        <div class="features__item" data-stagger>
          <div class="features__icon-wrap">
            <Icon name={f.icon} size={22} />
          </div>
          <div class="features__text">
            <h3>{f.title}</h3>
            <p>{f.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- <div class="features__guarantee">
      <Icon name="shield-check" size={28} class="features__guarantee-icon" />
      <div>
        <strong>Garantia de 30 dias</strong>
        <p>Não ficou satisfeito? Devolvemos seu dinheiro. Sem perguntas, sem burocracia.</p>
      </div>
    </div> -->
  </div>
</section>

<style>
  .features {
    background: var(--bg-white);
  }
  .features__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    margin-top: 32px;
  }
  .features__item {
    display: flex;
    align-items: center;
    gap: 14px;
    background: var(--bg-alt);
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    padding: 16px;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease, background 0.3s ease;
    cursor: default;
  }
  .features__item:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    border-color: #BFDBFE;
    background: var(--bg-white);
  }
  .features__item:hover .features__icon-wrap {
    background: var(--primary);
    color: var(--text-white);
    transform: scale(1.05);
  }
  .features__icon-wrap {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: #EFF6FF;
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }
  .features__text h3 {
    font-family: var(--font);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 2px;
  }
  .features__text p {
    font-family: var(--font);
    font-size: 12px;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .features__guarantee {
    display: flex;
    align-items: center;
    gap: 14px;
    background: #ECFDF5;
    border: 1.5px solid #BBF7D0;
    border-radius: var(--radius-md);
    padding: 20px;
    margin-top: 24px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .features__guarantee:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(34, 197, 94, 0.1);
  }
  .features__guarantee-icon {
    flex-shrink: 0;
    color: var(--success);
  }
  .features__guarantee strong {
    font-family: var(--font);
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    display: block;
    margin-bottom: 2px;
  }
  .features__guarantee p {
    font-family: var(--font);
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  @media (min-width: 1024px) {
    .features__grid {
      grid-template-columns: 1fr 1fr;
      gap: 16px 20px;
      max-width: 1000px;
      margin: 48px auto 0;
    }
    .features__item {
      padding: 20px;
    }
    .features__text h3 { font-size: 15px; }
    .features__text p { font-size: 13px; }
    .features__guarantee {
      max-width: 700px;
      margin: 32px auto 0;
      padding: 24px 28px;
      gap: 16px;
    }
  }
</style>
