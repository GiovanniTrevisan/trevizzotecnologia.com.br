---
import Icon from '@/components/ui/Icon.astro';
import Button from '@/components/ui/Button.astro';
import { WHATSAPP_URL } from '@/data/config';
---

<section class="final section" data-reveal>
  <div class="container">
    <div class="final__card">
      <div class="final__bg" aria-hidden="true"></div>
      <div class="grid-overlay" aria-hidden="true"></div>
      <div class="noise" aria-hidden="true"></div>

      <div class="final__content">
        <span class="eyebrow eyebrow--dark">
          <span class="eyebrow__dot"></span>
          Próximo passo
        </span>

        <h2 class="final__title">
          Em 7 dias seu negócio pode estar
          <span class="final__title-accent">aparecendo no Google.</span>
        </h2>

        <p class="final__sub">
          Cada dia sem presença digital é um cliente indo pro concorrente. Comece hoje — a primeira conversa é grátis e sem compromisso.
        </p>

        <div class="final__actions">
          <Button href="#orcamento" variant="primary" size="xl" dataCta="final-form">
            Quero meu orçamento
            <Icon name="arrow-right" size={18} />
          </Button>
          <Button href={WHATSAPP_URL} variant="glass" size="xl" dataCta="final-whats" target="_blank" rel="noopener noreferrer">
            <Icon name="whatsapp" size={18} />
            Falar pelo WhatsApp
          </Button>
        </div>

        <ul class="final__pills">
          <li><Icon name="zap" size={14} /> Resposta em até 1h útil</li>
          <li><Icon name="shield-check" size={14} /> Sem compromisso</li>
          <li><Icon name="users" size={14} /> Conversa direto com sócio</li>
        </ul>
      </div>

      <!-- Side visual -->
      <div class="final__visual" aria-hidden="true">
        <div class="final__orb final__orb--1"></div>
        <div class="final__orb final__orb--2"></div>
        <div class="final__stat">
          <strong data-count-to="7" data-count-suffix="">0</strong>
          <span>dias para entrega</span>
        </div>
        <div class="final__stat final__stat--2">
          <strong data-count-to="12" data-count-suffix=" meses">0 meses</strong>
          <span>de suporte humano</span>
        </div>
        <div class="final__stat final__stat--3">
          <strong>R$ 99<sup>,90</sup></strong>
          <span>por mês · 12x sem juros</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .final { background: var(--bg-base); position: relative; overflow: hidden; }

  .final__card {
    position: relative;
    background: rgba(20, 40, 68, 0.5);
    border: 1.5px solid rgba(232, 90, 37, 0.4);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: var(--radius-2xl);
    padding: 48px 28px;
    overflow: hidden;
    isolation: isolate;
    color: var(--text-primary);
    box-shadow: 0 0 60px rgba(232, 90, 37, 0.12), var(--shadow-xl);
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
    align-items: center;
  }
  @media (min-width: 900px) {
    .final__card {
      padding: 56px 48px;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 40px;
    }
  }
  @media (min-width: 1200px) {
    .final__card { padding: 72px; gap: 48px; }
  }

  .final__bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 0%, rgba(232,90,37,0.2), transparent 50%);
    pointer-events: none;
    z-index: -1;
  }

  .final__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .final__title {
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: var(--tracking-tighter);
    text-wrap: balance;
  }
  .final__title-accent {
    color: var(--accent);
    font-weight: 800;
  }
  .final__sub {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 560px;
  }
  .final__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .final__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }
  .final__pills li {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: var(--radius-full);
    background: rgba(246, 248, 252, 0.05);
    border: 1px solid rgba(246, 248, 252, 0.08);
    font-size: 12px;
    color: var(--text-secondary);
  }
  .final__pills :global(svg) { color: var(--accent); }

  /* Visual */
  .final__visual {
    position: relative;
    z-index: 1;
    min-height: 280px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 14px;
  }
  .final__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    pointer-events: none;
  }
  .final__orb--1 {
    width: 220px; height: 220px;
    background: rgba(232, 90, 37, 0.3);
    top: -40px; left: -20px;
  }
  .final__orb--2 {
    width: 180px; height: 180px;
    background: rgba(20, 40, 68, 0.6);
    bottom: -20px; right: -20px;
  }
  .final__stat {
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: var(--glass-border);
    border-radius: var(--radius-lg);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    z-index: 1;
    transition: transform 0.5s var(--ease-out-back);
  }
  .final__stat:hover { transform: translateY(-4px) scale(1.02); }
  .final__stat strong {
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 800;
    color: var(--accent);
    letter-spacing: var(--tracking-tighter);
    line-height: 1;
  }
  .final__stat strong sup {
    font-size: 0.5em;
    vertical-align: super;
    margin-left: 2px;
  }
  .final__stat span {
    font-size: 12.5px;
    color: var(--text-secondary);
    line-height: 1.4;
  }
  .final__stat--3 {
    grid-column: span 2;
  }
</style>
