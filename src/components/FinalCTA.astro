---
import Icon from '@/components/ui/Icon.astro';
import Button from '@/components/ui/Button.astro';
import { WHATSAPP_URL } from '@/data/config';
---

<section class="final-cta" data-reveal>
  <div class="container final-cta__inner">
    <Icon name="rocket" size={40} class="final-cta__icon" />
    <h2 class="final-cta__title">Pronto para ser encontrado no Google?</h2>
    <p class="final-cta__sub">
      Fale com a gente agora. Em 7 dias, seu negócio estará online.
    </p>
    <Button href={WHATSAPP_URL} variant="whatsapp" size="lg" dataCta="final-cta" target="_blank" rel="noopener noreferrer">
      <Icon name="message-circle" size={22} />
      Falar com a Trevizzo
    </Button>
    <span class="final-cta__note">Sem compromisso. Tire suas dúvidas primeiro.</span>
  </div>
</section>

<style>
  .final-cta {
    background: linear-gradient(180deg, #1E3A5F 0%, #0F172A 100%);
    padding: 64px 24px;
  }
  .final-cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
  }
  .final-cta__icon {
    color: #FF6B35;
    filter: drop-shadow(0 0 12px rgba(255, 107, 53, 0.4));
    animation: float 3s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .final-cta__title {
    font-family: var(--font);
    font-size: 22px;
    font-weight: 700;
    color: var(--text-white);
    line-height: 1.3;
    max-width: 600px;
  }
  .final-cta__sub {
    font-family: var(--font);
    font-size: 14px;
    color: #94A3B8;
    line-height: 1.5;
    max-width: 500px;
  }
  .final-cta__note {
    font-family: var(--font);
    font-size: 12px;
    color: #64748B;
  }

  @media (min-width: 1024px) {
    .final-cta {
      padding: 80px;
    }
    .final-cta__icon {
      width: 48px;
      height: 48px;
    }
    .final-cta__title { font-size: 36px; }
    .final-cta__sub { font-size: 16px; }
    .final-cta__note { font-size: 13px; }
  }
</style>
