---
import Icon from '@/components/ui/Icon.astro';
import Button from '@/components/ui/Button.astro';
import { WHATSAPP_URL } from '@/data/config';
---

<section class="final-cta" data-reveal>
  <div class="container final-cta__inner">
    <h2 class="final-cta__title">Pronto para ser encontrado no Google?</h2>
    <p class="final-cta__sub">
      Fale com a gente pelo WhatsApp. Em 7 dias, seu negócio aparece no Google.
    </p>
    <Button href={WHATSAPP_URL} variant="whatsapp" size="lg" dataCta="final-cta" target="_blank" rel="noopener noreferrer">
      <Icon name="message-circle" size={22} />
      Quero Meu Site no Google Agora
    </Button>
    <span class="final-cta__note">Sem compromisso · Garantia de 30 dias · Pagamento seguro</span>
  </div>
</section>

<style>
  .final-cta {
    background: transparent;
    padding: 64px 24px;
    position: relative;
  }
  .final-cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-radius: var(--radius-xl);
    padding: 48px 24px;
    max-width: 800px;
    margin: 0 auto;
  }
  .final-cta__title {
    font-family: var(--font);
    font-size: 22px;
    font-weight: 700;
    color: var(--text-white);
    line-height: 1.3;
    max-width: 600px;
  }
  .final-cta__sub {
    font-family: var(--font);
    font-size: 14px;
    color: #94A3B8;
    line-height: 1.5;
    max-width: 500px;
  }
  .final-cta__note {
    font-family: var(--font);
    font-size: 12px;
    color: #64748B;
  }

  @media (min-width: 1024px) {
    .final-cta {
      padding: 80px;
    }
    .final-cta__inner {
      padding: 64px 48px;
    }
    .final-cta__title { font-size: 36px; }
    .final-cta__sub { font-size: 16px; }
    .final-cta__note { font-size: 13px; }
  }
</style>
