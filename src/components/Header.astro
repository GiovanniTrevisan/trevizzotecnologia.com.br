---
import Icon from '@/components/ui/Icon.astro';
import Button from '@/components/ui/Button.astro';
import { WHATSAPP_URL } from '@/data/config';

interface Props {
  variant?: 'default' | 'light';
}

const { variant = 'default' } = Astro.props;

const navLinks = [
  { label: 'Benefícios', href: '/#beneficios' },
  { label: 'Como Funciona', href: '/#como-funciona' },
  { label: 'Preço', href: '/#preco' },
  { label: 'FAQ', href: '/#faq' },
];
---

<header class:list={['header', { 'header--light': variant === 'light' }]} id="header">
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label="Trevizzo Soluções - Página inicial">
      <img
        src="/images/logo.svg"
        alt="Trevizzo Soluções"
        width="160"
        height="49"
        class="header__logo-img header__logo-img--light"
      />
      <img
        src="/images/logo-dark.svg"
        alt="Trevizzo Soluções"
        width="160"
        height="49"
        class="header__logo-img header__logo-img--dark"
      />
    </a>

    <nav class="header__nav" aria-label="Navegação principal">
      {navLinks.map((link) => (
        <a href={link.href} class="header__link">{link.label}</a>
      ))}
    </nav>

    <Button href={WHATSAPP_URL} variant="primary" size="sm" class="header__cta" dataCta="header" target="_blank" rel="noopener noreferrer">
      Quero Meu Site →
    </Button>

    <button
      class="header__hamburger"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <Icon name="menu" size={22} class="header__hamburger-icon header__hamburger-icon--open" />
      <Icon name="x" size={22} class="header__hamburger-icon header__hamburger-icon--close" />
    </button>
  </div>
</header>

<!-- Mobile Menu (outside header to avoid backdrop-filter containing block) -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <nav class="mobile-menu__nav" aria-label="Menu mobile">
    {navLinks.map((link) => (
      <a href={link.href} class="mobile-menu__link">{link.label}</a>
    ))}
    <Button href={WHATSAPP_URL} variant="primary" size="md" class="mobile-menu__cta" dataCta="header-mobile" target="_blank" rel="noopener noreferrer">
      Quero Meu Site →
    </Button>
  </nav>
</div>

<script>
  const header = document.getElementById('header')!;
  const hamburger = header.querySelector('.header__hamburger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  // Sticky header
  const onScroll = () => {
    header.classList.toggle('header--scrolled', window.scrollY > 10);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu toggle
  hamburger.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.toggle('mobile-menu--open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu.setAttribute('aria-hidden', String(!isOpen));
    document.body.classList.toggle('menu-open', isOpen);
    header.classList.toggle('header--menu-open', isOpen);
  });

  // Close on link click
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('mobile-menu--open');
      hamburger.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('menu-open');
      header.classList.remove('header--menu-open');
    });
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: transparent;
    transition: background 0.3s, box-shadow 0.3s, backdrop-filter 0.3s;
  }
  .header--scrolled {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 1px 12px rgba(0, 0, 0, 0.08);
    border-bottom: 1px solid rgba(226, 232, 240, 0.6);
  }
  /* When menu is open, force solid white header with dark text */
  .header--menu-open {
    background: var(--bg-white) !important;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: 0 1px 12px rgba(0, 0, 0, 0.08);
  }
  .header--menu-open .header__hamburger {
    background: #F1F5F9;
    color: var(--primary);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 20px;
    height: 64px;
  }

  .header__logo {
    text-decoration: none;
    display: flex;
    align-items: center;
  }
  .header__logo-img {
    height: 48px;
    width: auto;
    display: block;
  }
  /* Light logo (for light/scrolled background) */
  .header__logo-img--light {
    display: block;
  }
  /* Dark logo (for dark hero background) */
  .header__logo-img--dark {
    display: none;
  }
  /* When over dark hero (not scrolled), show dark-bg logo and hide light logo */
  .header:not(.header--scrolled):not(.header--light) .header__logo-img--light {
    display: none;
  }
  .header:not(.header--scrolled):not(.header--light) .header__logo-img--dark {
    display: block;
  }
  /* When menu is open, keep light logo visible */
  .header--menu-open .header__logo-img--light {
    display: block !important;
  }
  .header--menu-open .header__logo-img--dark {
    display: none !important;
  }

  .header__nav {
    display: none;
    gap: 32px;
    align-items: center;
  }
  .header__link {
    font-family: var(--font);
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s;
    position: relative;
  }
  .header__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
    transition: width 0.3s ease;
  }
  .header__link:hover {
    color: var(--primary);
  }
  .header__link:hover::after {
    width: 100%;
  }
  .header:not(.header--scrolled):not(.header--light) .header__link {
    color: rgba(255, 255, 255, 0.85);
  }
  .header:not(.header--scrolled):not(.header--light) .header__link:hover {
    color: var(--text-white);
  }
  .header:not(.header--scrolled):not(.header--light) .header__link::after {
    background: var(--text-white);
  }

  .header__cta {
    display: none;
  }

  .header__hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: rgba(241, 245, 249, 0.15);
    color: var(--text-white);
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }
  .header--light .header__hamburger {
    background: #F1F5F9;
    color: var(--primary);
  }
  .header--scrolled .header__hamburger {
    background: #F1F5F9;
    color: var(--primary);
  }
  .header__hamburger :global(.header__hamburger-icon--close) {
    display: none;
  }
  .header__hamburger[aria-expanded="true"] :global(.header__hamburger-icon--open) {
    display: none;
  }
  .header__hamburger[aria-expanded="true"] :global(.header__hamburger-icon--close) {
    display: block;
  }

  /* Mobile Menu — styles moved to global block below */

  @media (min-width: 1024px) {
    .header__inner {
      padding: 0 80px;
      height: 72px;
    }
    .header__nav {
      display: flex;
    }
    .header__cta {
      display: inline-flex;
    }
    .header__hamburger {
      display: none;
    }
  }
</style>

