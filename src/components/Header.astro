    transition: opacity 0.3s, visibility 0.3s;
    z-index: 99;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .mobile-menu--open {
    opacity: 1;
    visibility: visible;
  }
  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 32px 24px;
  }
