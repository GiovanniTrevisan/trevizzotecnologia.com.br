    font-weight: 600;
    color: var(--text-primary);
    padding: 12px 24px;
    border-radius: var(--radius-sm);
    width: 100%;
    text-align: center;
    text-decoration: none;
    transition: background 0.2s;
  }
  .mobile-menu__link:hover {
    background: var(--bg-alt);
  }
  .mobile-menu__cta {
    margin-top: 16px;
    width: 100%;
  }
  @media (min-width: 1024px) {
    .mobile-menu {
      display: none !important;
