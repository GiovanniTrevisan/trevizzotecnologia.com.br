---
import Icon from '@/components/ui/Icon.astro';
import Button from '@/components/ui/Button.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { WHATSAPP_NUMBER } from '@/data/config';

const segments = [
  { value: 'beleza', label: 'Beleza & Estética', emoji: '💇', keyword: 'salão de beleza', rating: '4.9', reviews: 142 },
  { value: 'food', label: 'Alimentação', emoji: '🍕', keyword: 'restaurante', rating: '4.8', reviews: 287 },
  { value: 'servicos', label: 'Serviços', emoji: '🔧', keyword: 'assistência técnica', rating: '4.9', reviews: 96 },
  { value: 'saude', label: 'Saúde & Bem-estar', emoji: '💆', keyword: 'clínica', rating: '4.9', reviews: 168 },
  { value: 'comercio', label: 'Comércio local', emoji: '🛒', keyword: 'loja', rating: '4.7', reviews: 212 },
  { value: 'educacao', label: 'Educação', emoji: '📚', keyword: 'curso', rating: '5.0', reviews: 74 },
];
---

<section class="sim section" id="playground" data-reveal>
  <div class="mesh-bg" aria-hidden="true"></div>
  <div class="grid-overlay" aria-hidden="true"></div>

  <div class="container sim__container">
    <SectionHeading
      label="Playground interativo"
      title="Coloca a mão na massa — descubra seu potencial no Google"
      subtitle="Duas ferramentas. Sem cadastro. Sem enrolação. Brinque, experimente e veja o que a Trevizzo pode fazer pelo seu negócio."
      highlight="potencial no Google"
      variant="dark"
    />

    <div class="sim__tabs" role="tablist" aria-label="Ferramentas interativas">
      <button class="sim__tab is-active" data-tab="preview" role="tab" aria-selected="true">
        <Icon name="search" size={16} />
        <span>Simulador do Google</span>
      </button>
      <button class="sim__tab" data-tab="roi" role="tab" aria-selected="false">
        <Icon name="bar-chart" size={16} />
        <span>Calculadora de ROI</span>
      </button>
    </div>

    <!-- ============ TAB 1: SIMULADOR ============ -->
    <div class="sim__panel is-active" data-panel="preview" role="tabpanel">
      <div class="sim__grid">
        <!-- Inputs -->
        <div class="sim__controls">
          <h3 class="sim__controls-title">
            <span class="sim__step-num">1</span>
            Preencha com seu negócio
          </h3>
          <p class="sim__controls-hint">A pré-visualização atualiza em tempo real enquanto você digita.</p>

          <div class="sim__field">
            <label for="sim-name">Nome do seu negócio</label>
            <input id="sim-name" type="text" placeholder="Ex: Márcia Beauty Salão" maxlength="48" autocomplete="off" />
          </div>

          <div class="sim__field">
            <label for="sim-city">Sua cidade</label>
            <input id="sim-city" type="text" placeholder="Ex: Barueri" maxlength="32" autocomplete="off" />
          </div>

          <div class="sim__field">
            <label>Segmento</label>
            <div class="sim__chips" role="radiogroup" aria-label="Segmento">
              {segments.map((s, i) => (
                <button
                  type="button"
                  class={`sim__chip${i === 0 ? ' is-active' : ''}`}
                  data-seg={s.value}
                  data-seg-kw={s.keyword}
                  data-seg-emoji={s.emoji}
                  data-seg-rating={s.rating}
                  data-seg-reviews={s.reviews}
                  role="radio"
                  aria-checked={i === 0 ? 'true' : 'false'}
                >
                  <span class="sim__chip-emoji">{s.emoji}</span>
                  {s.label}
                </button>
              ))}
            </div>
          </div>

          <!-- Score gauge -->
          <div class="sim__score" aria-live="polite">
            <div class="sim__score-head">
              <span>Score de visibilidade local</span>
              <span class="sim__score-value">
                <span id="sim-score-now">—</span><span class="sim__score-sep">/</span><span>100</span>
              </span>
            </div>
            <div class="sim__bar">
              <div class="sim__bar-before" id="sim-bar-before" style="width: 0%;">
                <span>hoje</span>
              </div>
              <div class="sim__bar-after" id="sim-bar-after" style="width: 0%;">
                <span>com Trevizzo</span>
              </div>
            </div>
            <div class="sim__score-legend">
              <span><span class="dot dot--gray"></span> Sem presença digital</span>
              <span><span class="dot dot--accent"></span> Após otimização</span>
            </div>
          </div>

          <Button
            variant="primary"
            size="lg"
            dataCta="sim-send"
            id="sim-send"
            fullWidth
          >
            <Icon name="message-circle" size={16} />
            Quero isso para o meu negócio
          </Button>
        </div>

        <!-- Live Google Mockup -->
        <div class="sim__preview">
          <h3 class="sim__controls-title sim__controls-title--preview">
            <span class="sim__step-num">2</span>
            Veja o resultado em tempo real
          </h3>

          <div class="sim__browser">
            <div class="sim__browser-chrome">
              <div class="sim__dots"><span></span><span></span><span></span></div>
              <div class="sim__url"><Icon name="lock" size={11} /> google.com</div>
            </div>

            <div class="sim__browser-body">
              <div class="sim__search">
                <Icon name="search" size={15} />
                <span id="sim-query">salão de beleza barueri</span>
                <span class="sim__cursor"></span>
              </div>

              <div class="sim__filters">
                <span class="sim__fchip is-active">Tudo</span>
                <span class="sim__fchip">Maps</span>
                <span class="sim__fchip">Imagens</span>
                <span class="sim__fchip">Mais</span>
              </div>

              <div class="sim__label">3 resultados perto de você</div>

              <article class="sim__result sim__result--featured" id="sim-card">
                <div class="sim__badge">
                  <Icon name="sparkles" size={11} />
                  Resultado em destaque
                </div>
                <div class="sim__result-head">
                  <div class="sim__avatar" id="sim-avatar">MB</div>
                  <div>
                    <div class="sim__result-title" id="sim-title">Márcia Beauty Salão</div>
                    <div class="sim__result-url" id="sim-url">marciabeauty.com.br</div>
                  </div>
                </div>
                <div class="sim__result-desc" id="sim-desc">
                  Atendimento profissional em Barueri. Hora marcada, equipe experiente e ótima localização. Veja horários, avaliações e fale conosco.
                </div>
                <div class="sim__result-meta">
                  <span class="sim__rating">★★★★★ <b id="sim-rating">4.9</b></span>
                  <span>· <b id="sim-reviews">142</b> avaliações</span>
                  <span>· Aberto agora</span>
                </div>
              </article>

              <article class="sim__result sim__result--ghost">
                <div class="sim__ghost-line sim__ghost-line--title"></div>
                <div class="sim__ghost-line"></div>
              </article>
              <article class="sim__result sim__result--ghost">
                <div class="sim__ghost-line sim__ghost-line--title"></div>
                <div class="sim__ghost-line"></div>
              </article>
            </div>
          </div>

          <div class="sim__note">
            <Icon name="sparkles" size={14} />
            Isto é uma simulação. O resultado real depende de SEO técnico, Google Meu Negócio e conteúdo — e é exatamente o que a gente faz.
          </div>
        </div>
      </div>
    </div>

    <!-- ============ TAB 2: ROI ============ -->
    <div class="sim__panel" data-panel="roi" role="tabpanel" hidden>
      <div class="sim__grid sim__grid--roi">
        <div class="sim__controls">
          <h3 class="sim__controls-title">
            <span class="sim__step-num">1</span>
            Calcule o potencial do seu negócio
          </h3>
          <p class="sim__controls-hint">Mexa nos sliders com os dados do seu negócio. O gráfico atualiza sozinho.</p>

          <div class="sim__slider">
            <div class="sim__slider-head">
              <label for="roi-ticket">Ticket médio por cliente</label>
              <strong id="roi-ticket-val">R$ 80</strong>
            </div>
            <input id="roi-ticket" type="range" min="20" max="1000" step="10" value="80" />
            <div class="sim__slider-scale"><span>R$ 20</span><span>R$ 1.000</span></div>
          </div>

          <div class="sim__slider">
            <div class="sim__slider-head">
              <label for="roi-clients">Clientes por mês hoje</label>
              <strong id="roi-clients-val">40</strong>
            </div>
            <input id="roi-clients" type="range" min="5" max="500" step="5" value="40" />
            <div class="sim__slider-scale"><span>5</span><span>500</span></div>
          </div>

          <div class="sim__slider">
            <div class="sim__slider-head">
              <label for="roi-growth">Crescimento projetado com SEO local</label>
              <strong><span id="roi-growth-val">35</span>%</strong>
            </div>
            <input id="roi-growth" type="range" min="10" max="80" step="5" value="35" />
            <div class="sim__slider-scale"><span>conservador</span><span>agressivo</span></div>
          </div>

          <div class="sim__stats">
            <div class="sim__stat">
              <span class="sim__stat-label">Faturamento atual/mês</span>
              <strong class="sim__stat-value" id="roi-current">R$ 3.200</strong>
            </div>
            <div class="sim__stat sim__stat--highlight">
              <span class="sim__stat-label">Projeção no 12º mês</span>
              <strong class="sim__stat-value" id="roi-projected">R$ 4.320</strong>
              <span class="sim__stat-delta" id="roi-delta">+R$ 1.120/mês</span>
            </div>
          </div>
        </div>

        <div class="sim__preview">
          <h3 class="sim__controls-title sim__controls-title--preview">
            <span class="sim__step-num">2</span>
            Projeção em 12 meses
          </h3>

          <div class="sim__chart" aria-hidden="true">
            <div class="sim__chart-legend">
              <span class="sim__legend-item sim__legend-item--gray">
                <span class="sim__legend-line"></span>Faturamento atual
              </span>
              <span class="sim__legend-item sim__legend-item--orange">
                <span class="sim__legend-line"></span>Com Trevizzo
              </span>
            </div>
            <div class="sim__chart-body">
              <div class="sim__chart-yaxis" id="roi-yaxis"></div>
              <div class="sim__chart-main">
                <svg id="roi-chart" viewBox="0 0 600 160" preserveAspectRatio="none" class="sim__chart-svg"></svg>
                <div class="sim__chart-axis" id="roi-axis"></div>
              </div>
            </div>
          </div>

          <div class="sim__roi-summary">
            <div class="sim__roi-big">
              <span>Ganho acumulado em 12 meses</span>
              <strong id="roi-total">R$ 13.440</strong>
            </div>
            <div class="sim__roi-vs">
              <span>Investimento Trevizzo</span>
              <strong>R$ 1.198,80</strong>
              <small id="roi-multi">11x o investimento</small>
            </div>
          </div>

          <Button
            variant="primary"
            size="lg"
            dataCta="roi-send"
            id="roi-send"
            fullWidth
          >
            <Icon name="rocket" size={16} />
            Quero começar a colher esses resultados
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ WHATSAPP_NUMBER }}>
  // ============ TABS ============
  const tabs = document.querySelectorAll('.sim__tab');
  const panels = document.querySelectorAll('.sim__panel');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const id = tab.getAttribute('data-tab');
      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', String(active));
      });
      panels.forEach((p) => {
        const active = p.getAttribute('data-panel') === id;
        p.classList.toggle('is-active', active);
        if (active) p.removeAttribute('hidden'); else p.setAttribute('hidden', '');
      });
    });
  });

  // ============ SIMULATOR ============
  const nameEl = document.getElementById('sim-name');
  const cityEl = document.getElementById('sim-city');
  const chips = document.querySelectorAll('.sim__chip');
  const titleEl = document.getElementById('sim-title');
  const urlEl = document.getElementById('sim-url');
  const descEl = document.getElementById('sim-desc');
  const queryEl = document.getElementById('sim-query');
  const avatarEl = document.getElementById('sim-avatar');
  const ratingEl = document.getElementById('sim-rating');
  const reviewsEl = document.getElementById('sim-reviews');
  const scoreNow = document.getElementById('sim-score-now');
  const barBefore = document.getElementById('sim-bar-before');
  const barAfter = document.getElementById('sim-bar-after');
  const card = document.getElementById('sim-card');

  let state = {
    name: '',
    city: '',
    seg: 'beleza',
    kw: 'salão de beleza',
    emoji: '💇',
    rating: '4.9',
    reviews: 142,
  };

  function slugifyDomain(name) {
    if (!name) return 'seunegocio.com.br';
    const s = name.toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '')
      .slice(0, 22);
    return (s || 'seunegocio') + '.com.br';
  }

  function initials(name) {
    if (!name) return 'SN';
    const parts = name.trim().split(/\s+/).filter(Boolean);
    if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
    return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
  }

  function randomScoreBefore() {
    // pseudo-random stable score based on name length
    const name = (state.name || '').length;
    return 18 + ((name * 3) % 22); // 18-40
  }

  function render() {
    const displayName = state.name || 'Seu Negócio';
    const displayCity = state.city || 'sua cidade';
    const kw = state.kw;

    titleEl.textContent = displayName;
    urlEl.textContent = slugifyDomain(state.name);
    descEl.textContent =
      `${displayName} — atendimento profissional em ${displayCity}. Equipe qualificada, horários flexíveis e ótima localização. Veja avaliações, horários e fale direto pelo WhatsApp.`;
    queryEl.textContent = `${kw} ${displayCity.toLowerCase()}`.trim();
    avatarEl.textContent = initials(state.name);
    ratingEl.textContent = state.rating;
    reviewsEl.textContent = String(state.reviews);

    const before = randomScoreBefore();
    const after = 88 + ((state.name || '').length % 10); // 88-97

    barBefore.style.width = before + '%';
    barAfter.style.width = after + '%';

    // Animate the "now" number
    animateNumber(scoreNow, before, after);

    // Pulse card
    card.classList.remove('is-pulsing');
    void card.offsetWidth;
    card.classList.add('is-pulsing');
  }

  let animHandle = null;
  function animateNumber(el, from, to) {
    if (animHandle) cancelAnimationFrame(animHandle);
    const start = performance.now();
    const dur = 900;
    function tick(now) {
      const p = Math.min(1, (now - start) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      const v = Math.round(from + (to - from) * eased);
      el.textContent = String(v);
      if (p < 1) animHandle = requestAnimationFrame(tick);
    }
    animHandle = requestAnimationFrame(tick);
  }

  if (nameEl) nameEl.addEventListener('input', (e) => { state.name = e.target.value; render(); });
  if (cityEl) cityEl.addEventListener('input', (e) => { state.city = e.target.value; render(); });

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => { c.classList.remove('is-active'); c.setAttribute('aria-checked', 'false'); });
      chip.classList.add('is-active');
      chip.setAttribute('aria-checked', 'true');
      state.seg = chip.getAttribute('data-seg');
      state.kw = chip.getAttribute('data-seg-kw');
      state.emoji = chip.getAttribute('data-seg-emoji');
      state.rating = chip.getAttribute('data-seg-rating');
      state.reviews = parseInt(chip.getAttribute('data-seg-reviews'), 10);
      render();
    });
  });

  render();

  // CTA do simulador -> WhatsApp pré-preenchido
  const simSend = document.getElementById('sim-send');
  if (simSend) {
    simSend.addEventListener('click', () => {
      const lines = [
        'Olá! Brinquei com o simulador do site e queria ver isso acontecer de verdade 🚀',
        '',
        '*Negócio:* ' + (state.name || '(vou te contar)'),
        '*Cidade:* ' + (state.city || '(vou te contar)'),
        '*Segmento:* ' + state.kw,
      ];
      const url = 'https://wa.me/' + WHATSAPP_NUMBER + '?text=' + encodeURIComponent(lines.join('\n'));
      window.open(url, '_blank', 'noopener');
    });
  }

  // ============ ROI CALCULATOR ============
  const ticketEl = document.getElementById('roi-ticket');
  const clientsEl = document.getElementById('roi-clients');
  const growthEl = document.getElementById('roi-growth');
  const ticketVal = document.getElementById('roi-ticket-val');
  const clientsVal = document.getElementById('roi-clients-val');
  const growthVal = document.getElementById('roi-growth-val');
  const currentEl = document.getElementById('roi-current');
  const projectedEl = document.getElementById('roi-projected');
  const deltaEl = document.getElementById('roi-delta');
  const totalEl = document.getElementById('roi-total');
  const multiEl = document.getElementById('roi-multi');
  const axisEl = document.getElementById('roi-axis');
  const yaxisEl = document.getElementById('roi-yaxis');

  const BRL = (n) => n.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL', maximumFractionDigits: 0 });

  function renderROI() {
    const ticket = parseInt(ticketEl.value, 10);
    const clients = parseInt(clientsEl.value, 10);
    const growth = parseInt(growthEl.value, 10);

    ticketVal.textContent = BRL(ticket);
    clientsVal.textContent = clients;
    growthVal.textContent = growth;

    const current = ticket * clients;
    // Mês 1-6: ramp-up ease-out (salto maior nos primeiros meses).
    // Mês 7-12: crescimento contínuo sutil (+1,5% a.m. simples sobre o plateau).
    const months = 12;
    const ramp = [];
    for (let i = 0; i < months; i++) {
      const monthIdx = i + 1;
      let factor;
      if (monthIdx <= 6) {
        const p = monthIdx / 6;
        const eased = 1 - Math.pow(1 - p, 2);
        factor = 1 + (growth / 100) * eased;
      } else {
        const extra = (monthIdx - 6) * 0.015;
        factor = (1 + growth / 100) * (1 + extra);
      }
      ramp.push({ month: monthIdx, value: Math.round(current * factor), base: current });
    }

    const projected = ramp[ramp.length - 1].value;
    const delta = projected - current;
    const totalGain = ramp.reduce((acc, m) => acc + (m.value - m.base), 0);
    const invest = 1198.8;
    const multi = Math.max(1, Math.round(totalGain / invest));

    currentEl.textContent = BRL(current);
    projectedEl.textContent = BRL(projected);
    deltaEl.textContent = '+' + BRL(delta) + '/mês';
    totalEl.textContent = BRL(totalGain);
    multiEl.textContent = multi + 'x o investimento';

    // render SVG line chart
    const labels = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
    axisEl.innerHTML = labels.slice(0, months).map((l) => `<span>${l}</span>`).join('');

    const svg = document.getElementById('roi-chart');
    if (!svg) return;
    const W = 600, H = 160;
    const padL = 4, padR = 4, padT = 12, padB = 8;
    const chartW = W - padL - padR;
    const chartH = H - padT - padB;

    const allVals = ramp.flatMap((m) => [m.base, m.value]);
    const minVal = Math.min(...allVals) * 0.88;
    const maxVal = Math.max(...allVals) * 1.06;

    const xS = (i) => padL + (i / (months - 1)) * chartW;
    const yS = (v) => padT + chartH - ((v - minVal) / (maxVal - minVal)) * chartH;

    const basePts = ramp.map((m, i) => [xS(i), yS(m.base)]);
    const growPts = ramp.map((m, i) => [xS(i), yS(m.value)]);

    function smoothPath(pts) {
      let d = `M ${pts[0][0]},${pts[0][1]}`;
      for (let i = 0; i < pts.length - 1; i++) {
        const cx1 = pts[i][0] + (pts[i+1][0] - pts[i][0]) / 3;
        const cx2 = pts[i+1][0] - (pts[i+1][0] - pts[i][0]) / 3;
        d += ` C ${cx1},${pts[i][1]} ${cx2},${pts[i+1][1]} ${pts[i+1][0]},${pts[i+1][1]}`;
      }
      return d;
    }

    function areaPath(pts) {
      const bot = padT + chartH;
      return smoothPath(pts) + ` L ${pts[pts.length-1][0]},${bot} L ${pts[0][0]},${bot} Z`;
    }

    const gridLines = [0.25, 0.5, 0.75, 1].map((f) => {
      const y = padT + chartH - f * chartH;
      return `<line x1="${padL}" y1="${y}" x2="${W - padR}" y2="${y}" stroke="rgba(255,255,255,0.07)" stroke-width="1" stroke-dasharray="4 4"/>`;
    }).join('');

    // Y-axis labels — alinhados exatamente às gridlines do SVG.
    // Nota: usamos o seletor descendente `.sim__chart-yaxis span` no CSS porque
    // classes aplicadas via innerHTML perdem o hash de escopo do Astro.
    if (yaxisEl) {
      const BRLshort = (n) => {
        if (n >= 1000) return 'R$\u00a0' + (n / 1000).toLocaleString('pt-BR', { minimumFractionDigits: 1, maximumFractionDigits: 1 }) + 'k';
        return 'R$\u00a0' + n.toLocaleString('pt-BR');
      };
      const yFracs = [1, 0.75, 0.5, 0.25];
      yaxisEl.innerHTML = yFracs.map((f) => {
        const val = Math.round(minVal + f * (maxVal - minVal));
        const topPx = padT + chartH - f * chartH;
        return `<span style="color: #94A3B8; font-size: 13px;">${BRLshort(val)}</span>`;
      }).join('');
    }

    const lb = basePts[basePts.length - 1];
    const lg = growPts[growPts.length - 1];

    svg.innerHTML = `
      <defs>
        <linearGradient id="grad-orange" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#FF6B35" stop-opacity="0.30"/>
          <stop offset="100%" stop-color="#FF6B35" stop-opacity="0.02"/>
        </linearGradient>
        <linearGradient id="grad-gray" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#94A3B8" stop-opacity="0.18"/>
          <stop offset="100%" stop-color="#94A3B8" stop-opacity="0.02"/>
        </linearGradient>
        <filter id="glow-orange">
          <feGaussianBlur stdDeviation="3" result="blur"/>
          <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
      </defs>
      ${gridLines}
      <path d="${areaPath(basePts)}" fill="url(#grad-gray)"/>
      <path d="${areaPath(growPts)}" fill="url(#grad-orange)"/>
      <path d="${smoothPath(basePts)}" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round"/>
      <path d="${smoothPath(growPts)}" fill="none" stroke="#FF6B35" stroke-width="2.5" stroke-linecap="round" filter="url(#glow-orange)"/>
      <circle cx="${lb[0]}" cy="${lb[1]}" r="4" fill="#94A3B8" stroke="#0F1B30" stroke-width="2"/>
      <circle cx="${lg[0]}" cy="${lg[1]}" r="5" fill="#FF6B35" stroke="#0F1B30" stroke-width="2" filter="url(#glow-orange)"/>
    `;
  }

  [ticketEl, clientsEl, growthEl].forEach((el) => {
    if (el) el.addEventListener('input', renderROI);
  });
  if (ticketEl) renderROI();

  const roiSend = document.getElementById('roi-send');
  if (roiSend) {
    roiSend.addEventListener('click', () => {
      const ticket = parseInt(ticketEl.value, 10);
      const clients = parseInt(clientsEl.value, 10);
      const growth = parseInt(growthEl.value, 10);
      const lines = [
        'Olá! Calculei meu ROI pelo site da Trevizzo 📊',
        '',
        '*Ticket médio:* ' + BRL(ticket),
        '*Clientes/mês hoje:* ' + clients,
        '*Crescimento alvo:* ' + growth + '%',
        '*Potencial anual:* ' + totalEl.textContent,
        '',
        'Quero conversar sobre o pacote de landing page + SEO.',
      ];
      const url = 'https://wa.me/' + WHATSAPP_NUMBER + '?text=' + encodeURIComponent(lines.join('\n'));
      window.open(url, '_blank', 'noopener');
    });
  }
</script>

