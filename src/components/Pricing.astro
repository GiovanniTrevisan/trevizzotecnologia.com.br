---
import Icon from '@/components/ui/Icon.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Button from '@/components/ui/Button.astro';
import { WHATSAPP_URL } from '@/data/config';

const checklist = [
  { text: 'Landing page profissional sob medida', highlight: true },
  { text: 'SEO técnico + on-page completo', highlight: true },
  { text: 'Google Meu Negócio configurado e otimizado', highlight: true },
  { text: 'Domínio .com.br + hospedagem + SSL' },
  { text: 'Botão WhatsApp e formulários integrados' },
  { text: '12 meses de suporte humano via WhatsApp', highlight: true },
  { text: 'Site 100% responsivo (mobile, tablet, desktop)' },
  { text: 'Entrega garantida em 7 dias úteis' },
];

const comparison = [
  { item: 'Landing page profissional',     us: true, agency: true,  freelance: 'parcial' },
  { item: 'SEO técnico + Google Meu Negócio', us: true, agency: 'extra', freelance: false },
  { item: 'Domínio + hospedagem inclusos', us: true, agency: 'extra', freelance: false },
  { item: 'Suporte humano por 12 meses',   us: true, agency: 'extra', freelance: false },
  { item: 'Entrega em 7 dias',             us: true, agency: false, freelance: 'parcial' },
  { item: 'Pagamento parcelado em 12x',    us: true, agency: 'parcial', freelance: false },
];
---

<section class="pricing section" id="preco" data-reveal>
  <div class="mesh-bg" aria-hidden="true"></div>

  <div class="container pricing__container">
    <SectionHeading
      label="Investimento"
      title="Menos de R$3,30 por dia. O preço de um café."
      subtitle="Plano único, transparente e sem letra miúda. Você paga uma vez no parcelado e recebe tudo o que precisa pra crescer."
      highlight="R$3,30"
    />

    <div class="pricing__layout">
      <!-- Card de preço -->
      <div class="pricing__card">
        <div class="pricing__card-glow"></div>

        <div class="pricing__card-head">
          <span class="pricing__badge">
            <Icon name="sparkles" size={12} />
            Pacote Essencial
          </span>
          <h3 class="pricing__plan">Plano Trevizzo Essencial</h3>
        </div>

        <div class="pricing__price-block">
          <span class="pricing__anchor">De <s>R$ 4.997</s> por</span>
          <div class="pricing__price">
            <span class="pricing__prefix">12x de</span>
            <strong class="pricing__value">R$ 99<sup>,90</sup></strong>
          </div>
          <span class="pricing__cash">ou R$ 1.198,80 à vista</span>
          <div class="pricing__per-day">
            <Icon name="zap" size={14} />
            <span>Equivale a R$ 3,29/dia</span>
          </div>
        </div>

        <hr class="pricing__divider" />

        <ul class="pricing__checklist">
          {checklist.map((item) => (
            <li class:list={['pricing__check-item', { 'pricing__check-item--hl': item.highlight }]} data-stagger>
              <span class="pricing__check-icon"><Icon name="check" size={14} /></span>
              <span>{item.text}</span>
            </li>
          ))}
        </ul>

        <div class="pricing__actions">
          <Button href="#orcamento" variant="primary" size="xl" fullWidth dataCta="pricing-form">
            Quero meu site agora
            <Icon name="arrow-right" size={18} />
          </Button>
          <Button href={WHATSAPP_URL} variant="ghost" size="lg" fullWidth dataCta="pricing-whats" target="_blank" rel="noopener noreferrer">
            <Icon name="whatsapp" size={16} />
            Tirar dúvidas no WhatsApp
          </Button>
        </div>

        <div class="pricing__trust">
          <div class="pricing__trust-item">
            <Icon name="shield-check" size={14} class="pricing__trust-icon pricing__trust-icon--green" />
            <span>Sem fidelidade</span>
          </div>
          <div class="pricing__trust-item">
            <Icon name="lock" size={14} class="pricing__trust-icon pricing__trust-icon--blue" />
            <span>Pagamento 100% seguro</span>
          </div>
          <div class="pricing__trust-item">
            <Icon name="users" size={14} class="pricing__trust-icon pricing__trust-icon--accent" />
            <span>Atendimento humano</span>
          </div>
        </div>
      </div>

      <!-- Tabela comparativa -->
      <aside class="pricing__compare">
        <h3 class="pricing__compare-title">Por que sai melhor que ir numa agência?</h3>
        <p class="pricing__compare-sub">Comparamos a Trevizzo com as 2 alternativas que você provavelmente está avaliando agora.</p>

        <div class="pricing__compare-table">
          <div class="pricing__compare-head">
            <span></span>
            <span class="pricing__compare-col pricing__compare-col--us">Trevizzo</span>
            <span class="pricing__compare-col">Agência</span>
            <span class="pricing__compare-col">Freelancer</span>
          </div>
          {comparison.map((row) => (
            <div class="pricing__compare-row">
              <span class="pricing__compare-label">{row.item}</span>
              <span class="pricing__compare-cell pricing__compare-cell--us">
                {row.us === true && <Icon name="check" size={16} />}
              </span>
              <span class="pricing__compare-cell">
                {row.agency === true   && <Icon name="check" size={16} class="pricing__check-good" />}
                {row.agency === false  && <Icon name="x" size={16} class="pricing__check-bad" />}
                {row.agency === 'extra'   && <span class="pricing__cell-tag">Custo extra</span>}
                {row.agency === 'parcial' && <span class="pricing__cell-tag">Parcial</span>}
              </span>
              <span class="pricing__compare-cell">
                {row.freelance === true   && <Icon name="check" size={16} class="pricing__check-good" />}
                {row.freelance === false  && <Icon name="x" size={16} class="pricing__check-bad" />}
                {row.freelance === 'parcial' && <span class="pricing__cell-tag">Parcial</span>}
              </span>
            </div>
          ))}
          <div class="pricing__compare-row pricing__compare-row--price">
            <span class="pricing__compare-label">Investimento médio</span>
            <span class="pricing__compare-cell pricing__compare-cell--us">
              <strong>R$ 1.198</strong>
            </span>
            <span class="pricing__compare-cell">R$ 5–15k</span>
            <span class="pricing__compare-cell">R$ 800–3k</span>
          </div>
        </div>

        <div class="pricing__compare-conclusion">
          <Icon name="thumbs-up" size={16} />
          <span><strong>Você economiza até 92%</strong> sem abrir mão de qualidade ou suporte.</span>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .pricing { background: var(--bg-base); position: relative; overflow: hidden; }
  .pricing__container { position: relative; z-index: 1; }

  .pricing__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    margin-top: 56px;
    align-items: stretch;
  }
  @media (min-width: 1100px) {
    .pricing__layout {
      grid-template-columns: 1.05fr 0.95fr;
      gap: 36px;
    }
  }

  /* Pricing card */
  .pricing__card {
    position: relative;
    background: rgba(20, 40, 68, 0.5);
    border: 1.5px solid rgba(232, 90, 37, 0.4);
    border-radius: var(--radius-2xl);
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    box-shadow: 0 0 60px rgba(232, 90, 37, 0.12), var(--shadow-lg);
    overflow: hidden;
    isolation: isolate;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
  @media (min-width: 768px) {
    .pricing__card { padding: 44px 40px; }
  }
  .pricing__card-glow {
    position: absolute;
    top: -120px; right: -120px;
    width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(232,90,37,0.2), transparent 70%);
    filter: blur(40px);
    pointer-events: none;
    z-index: -1;
  }

  .pricing__card-head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  .pricing__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--accent);
    color: var(--text-primary);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: var(--radius-full);
    box-shadow: 0 4px 14px rgba(232, 90, 37, 0.3);
  }
  .pricing__plan {
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: var(--tracking-tight);
  }

  .pricing__price-block {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .pricing__anchor {
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 500;
  }
  .pricing__anchor s { color: #94A3B8; }
  .pricing__price {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .pricing__prefix {
    font-size: 16px;
    color: var(--text-secondary);
    font-weight: 500;
  }
  .pricing__value {
    font-size: clamp(48px, 7vw, 68px);
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: var(--tracking-tighter);
  }
  .pricing__value sup {
    font-size: 0.42em;
    font-weight: 700;
    vertical-align: super;
    color: var(--text-secondary);
    margin-left: 2px;
  }
  .pricing__cash {
    font-size: 13px;
    color: var(--text-secondary);
    font-weight: 500;
  }
  .pricing__per-day {
    margin-top: 8px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    align-self: flex-start;
    background: rgba(255, 107, 53, 0.08);
    color: var(--accent);
    font-size: 12px;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: var(--radius-full);
  }

  .pricing__divider {
    border: none;
    height: 1px;
    background: var(--border-soft);
  }

  .pricing__checklist {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }
  @media (min-width: 600px) {
    .pricing__checklist { grid-template-columns: 1fr 1fr; gap: 12px 20px; }
  }
  .pricing__check-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--text-primary);
    line-height: 1.4;
  }
  .pricing__check-icon {
    flex-shrink: 0;
    width: 22px; height: 22px;
    border-radius: 50%;
    background: rgba(255, 232, 220, 0.12);
    color: var(--accent-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }
  .pricing__check-item--hl {
    font-weight: 600;
  }
  .pricing__check-item--hl .pricing__check-icon {
    background: var(--accent);
    color: var(--text-primary);
    box-shadow: 0 4px 10px rgba(232, 90, 37, 0.35);
  }

  .pricing__actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pricing__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
    padding-top: 8px;
  }
  .pricing__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    font-weight: 500;
    color: var(--text-secondary);
  }
  .pricing__trust-icon--green   { color: var(--success); }
  .pricing__trust-icon--blue    { color: var(--primary); }
  .pricing__trust-icon--accent  { color: var(--accent); }

  /* Compare panel */
  .pricing__compare {
    background: var(--glass-bg);
    border: var(--glass-border);
    border-radius: var(--radius-2xl);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .pricing__compare { padding: 36px; }
  }
  .pricing__compare-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: var(--tracking-tight);
    line-height: 1.3;
  }
  .pricing__compare-sub {
    font-size: 13.5px;
    color: var(--text-secondary);
    line-height: 1.55;
  }
  .pricing__compare-table {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 8px;
  }
  .pricing__compare-head,
  .pricing__compare-row {
    display: grid;
    grid-template-columns: 1.4fr 0.7fr 0.7fr 0.7fr;
    align-items: center;
    gap: 6px;
    padding: 10px 6px;
    border-radius: var(--radius-sm);
  }
  @media (min-width: 480px) {
    .pricing__compare-head,
    .pricing__compare-row {
      grid-template-columns: 1.6fr 0.9fr 0.9fr 0.9fr;
      gap: 4px;
      padding: 10px 8px;
    }
  }
  .pricing__compare-head {
    font-size: 11.5px;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--border-soft);
  }
  .pricing__compare-col { text-align: center; }
  .pricing__compare-col--us {
    color: var(--accent);
  }
  .pricing__compare-row { font-size: 12.5px; }
  @media (min-width: 480px) {
    .pricing__compare-row { font-size: 13px; }
  }
  .pricing__compare-row:nth-child(odd) { background: var(--bg-alt); }
  .pricing__compare-label {
    color: var(--text-primary);
    font-weight: 500;
    font-size: 12px;
    line-height: 1.3;
  }
  @media (min-width: 480px) {
    .pricing__compare-label { font-size: 13px; }
  }
  .pricing__compare-cell {
    text-align: center;
    color: var(--text-secondary);
    font-size: 11.5px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  @media (min-width: 480px) {
    .pricing__compare-cell { font-size: 12.5px; }
  }
  .pricing__compare-cell--us {
    background: rgba(255, 107, 53, 0.08);
    border-radius: 6px;
    color: var(--accent);
    font-weight: 600;
    padding: 6px 4px;
    margin: -6px 0;
  }
  .pricing__compare-cell--us strong {
    font-size: 14px;
    font-weight: 700;
  }
  .pricing__check-good { color: var(--success); }
  .pricing__check-bad  { color: #94A3B8; }
  .pricing__cell-tag {
    font-size: 10.5px;
    background: var(--bg-soft);
    color: var(--text-muted);
    padding: 3px 8px;
    border-radius: var(--radius-full);
    font-weight: 600;
  }

  .pricing__compare-row--price {
    margin-top: 8px;
    background: rgba(232, 90, 37, 0.06) !important;
    font-weight: 600;
  }

  .pricing__compare-conclusion {
    margin-top: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    background: rgba(255, 232, 220, 0.06);
    border: 1px solid rgba(232, 90, 37, 0.25);
    border-radius: var(--radius-md);
    font-size: 13.5px;
    color: var(--accent-soft);
    line-height: 1.4;
  }
  .pricing__compare-conclusion strong { font-weight: 700; }
</style>
