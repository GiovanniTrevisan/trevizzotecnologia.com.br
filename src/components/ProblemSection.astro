---
import Icon from '@/components/ui/Icon.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';

const problems = [
  {
    icon: 'search-x',
    accent: '#EF4444',
    title: 'Você está invisível no Google',
    description: 'Quando alguém pesquisa pelo seu serviço na sua região, é o concorrente que aparece — não você.',
    stat: '70%',
    statLabel: 'das PMEs sem site',
  },
  {
    icon: 'instagram',
    accent: '#A855F7',
    title: 'Instagram não basta',
    description: 'Redes sociais não substituem um site. O Google prioriza quem tem presença profissional fora delas.',
    stat: '8 em 10',
    statLabel: 'clientes pesquisam antes',
  },
  {
    icon: 'banknote',
    accent: '#F59E0B',
    title: 'Agências cobram fortunas',
    description: 'Sites de R$ 5.000 a R$ 15.000 não são feitos para o pequeno empreendedor. O ROI nunca fecha.',
    stat: 'R$ 5k+',
    statLabel: 'cobrado em média',
  },
];

const stats = [
  { value: 14, suffix: 'M+',  label: 'pequenos negócios no Brasil',          decimals: 0 },
  { value: 73, suffix: '%',   label: 'sem site profissional ativo',           decimals: 0 },
  { value: 7,  suffix: ' dias',label: 'até estar no topo do Google local',    decimals: 0 },
  { value: 312,suffix: '%',   label: 'média de aumento em buscas',            decimals: 0 },
];
---

<section class="problem section" id="beneficios" data-reveal>
  <div class="mesh-bg mesh-bg--light" aria-hidden="true"></div>

  <div class="container problem__container">
    <SectionHeading
      label="O Problema"
      title="Pequenos negócios estão invisíveis para quem mais importa: o cliente local"
      subtitle="Enquanto você cuida do que faz de melhor, seu concorrente está aparecendo na primeira página do Google. A boa notícia: dá pra mudar isso em uma semana."
      highlight="invisíveis"
    />

    <div class="problem__cards">
      {problems.map((p) => (
        <article class="problem__card" data-stagger>
          <div class="problem__card-top">
            <div class="problem__icon" style={`--ico: ${p.accent}`}>
              <Icon name={p.icon} size={22} />
            </div>
            <div class="problem__stat">
              <strong>{p.stat}</strong>
              <span>{p.statLabel}</span>
            </div>
          </div>
          <h3 class="problem__title">{p.title}</h3>
          <p class="problem__desc">{p.description}</p>
        </article>
      ))}
    </div>

    <!-- Big stats strip -->
    <div class="problem__bigstats">
      {stats.map((s) => (
        <div class="problem__bigstat" data-stagger>
          <strong
            data-count-to={s.value}
            data-count-suffix={s.suffix}
            data-count-decimals={s.decimals}
          >0{s.suffix}</strong>
          <span>{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .problem {
    background: var(--bg-base);
    overflow: hidden;
  }
  .problem__container { position: relative; z-index: 1; }

  .problem__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-top: 56px;
  }
  @media (min-width: 768px) {
    .problem__cards { grid-template-columns: repeat(3, 1fr); gap: 20px; }
  }

  .problem__card {
    background: var(--glass-bg);
    border: var(--glass-border);
    border-radius: var(--radius-xl);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: transform 0.5s var(--ease-out-expo), box-shadow 0.5s, border-color 0.4s;
    position: relative;
    overflow: hidden;
  }
  .problem__card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.6s var(--ease-out-expo);
  }
  .problem__card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(232, 90, 37, 0.4);
  }
  .problem__card:hover::before { transform: scaleX(1); }

  .problem__card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }
  .problem__icon {
    width: 48px; height: 48px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--ico) 12%, transparent);
    color: var(--ico);
    transition: transform 0.5s var(--ease-out-back);
  }
  .problem__card:hover .problem__icon { transform: scale(1.08) rotate(-4deg); }

  .problem__stat {
    text-align: right;
  }
  .problem__stat strong {
    display: block;
    font-size: 22px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
  }
  .problem__stat span {
    font-size: 11px;
    color: var(--text-muted);
    font-weight: 500;
  }

  .problem__title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    letter-spacing: var(--tracking-tight);
  }
  .problem__desc {
    font-size: 14.5px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Big stats */
  .problem__bigstats {
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    background: var(--bg-surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-2xl);
    padding: 36px 24px;
    color: var(--text-primary);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }
  .problem__bigstats::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 20%, rgba(232,90,37,0.12), transparent 60%);
    pointer-events: none;
  }
  @media (min-width: 768px) {
    .problem__bigstats {
      grid-template-columns: repeat(4, 1fr);
      padding: 48px 36px;
      gap: 32px;
    }
  }
  .problem__bigstat {
    text-align: center;
    position: relative;
  }
  .problem__bigstat strong {
    display: block;
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 800;
    color: var(--accent);
    letter-spacing: var(--tracking-tighter);
    line-height: 1;
    transition: transform 0.3s ease;
  }
  .problem__bigstat strong:hover {
    transform: scale(1.1);
  }
  .problem__bigstat span {
    display: block;
    font-size: 13px;
    margin-top: 6px;
    color: var(--text-secondary);
    line-height: 1.4;
  }
</style>
