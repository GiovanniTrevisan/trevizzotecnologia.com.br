---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'whatsapp' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  dataCta?: string;
  [key: string]: any;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  dataCta,
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
  data-cta={dataCta}
  {...rest}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: var(--font);
    font-weight: 600;
    border-radius: var(--radius-md);
    transition: background 0.2s, transform 0.2s, box-shadow 0.3s;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    border: none;
    position: relative;
    overflow: hidden;
  }
  .btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,0.15) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 0.5s ease;
  }
  .btn:hover::after {
    transform: translateX(100%);
  }
  .btn:hover {
    transform: translateY(-2px);
  }
  .btn:active {
    transform: translateY(0);
  }

  .btn--sm { font-size: 13px; padding: 8px 16px; }
  .btn--md { font-size: 15px; padding: 12px 24px; }
  .btn--lg { font-size: 16px; padding: 16px 32px; height: 56px; }

  .btn--primary {
    background: var(--accent);
    color: var(--text-white);
    box-shadow: 0 4px 20px rgba(255, 107, 53, 0.3);
    border: 1px solid rgba(255, 107, 53, 0.4);
  }
  .btn--primary:hover {
    background: var(--accent-hover);
    box-shadow: 0 6px 28px rgba(255, 107, 53, 0.45);
  }

  .btn--secondary {
    background: transparent;
    color: #94A3B8;
    font-weight: 500;
  }
  .btn--secondary:hover {
    color: var(--text-white);
  }

  .btn--whatsapp {
    background: var(--whatsapp-green);
    color: var(--text-white);
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.3);
    border: 1px solid rgba(37, 211, 102, 0.4);
  }
  .btn--whatsapp:hover {
    background: #1fb855;
    box-shadow: 0 6px 28px rgba(37, 211, 102, 0.45);
  }

  .btn--outline {
    background: rgba(255, 255, 255, 0.05);
    color: var(--accent);
    border: 2px solid var(--accent);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
  }
  .btn--outline:hover {
    background: var(--accent);
    color: var(--text-white);
  }
</style>
