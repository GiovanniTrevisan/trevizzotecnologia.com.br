---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'whatsapp' | 'outline' | 'ghost' | 'glass';
  size?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
  dataCta?: string;
  fullWidth?: boolean;
  [key: string]: any;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  dataCta,
  fullWidth = false,
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  class:list={['btn', `btn--${variant}`, `btn--${size}`, { 'btn--full': fullWidth }, className]}
  data-cta={dataCta}
  {...rest}
>
  <span class="btn__inner"><slot /></span>
</Tag>

<style>
  .btn {
    --btn-bg: var(--accent);
    --btn-color: var(--text-white);
    --btn-shadow: 0 8px 28px rgba(232, 90, 37, 0.38);
    --btn-shadow-hover: 0 14px 42px rgba(232, 90, 37, 0.52);

    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--font);
    font-weight: 600;
    letter-spacing: -0.01em;
    border-radius: var(--radius-md);
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    border: none;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background: var(--btn-bg);
    color: var(--btn-color);
    box-shadow: var(--btn-shadow);
    transition:
      transform 0.35s var(--ease-out-back),
      box-shadow 0.35s var(--ease-out-expo),
      background 0.25s ease,
      color 0.25s ease;
  }
  .btn__inner {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 25%, rgba(255,255,255,0.22) 50%, transparent 75%);
    transform: translateX(-120%);
    transition: transform 0.7s var(--ease-out-expo);
    z-index: 1;
  }
  .btn:hover::before { transform: translateX(120%); }
  .btn:hover { transform: translateY(-3px); box-shadow: var(--btn-shadow-hover); }
  .btn:active { transform: translateY(-1px); }
  .btn--full { width: 100%; }

  /* Sizes */
  .btn--sm  { font-size: 13px; padding: 9px 16px;  border-radius: var(--radius-sm); }
  .btn--md  { font-size: 15px; padding: 13px 22px; }
  .btn--lg  { font-size: 16px; padding: 16px 28px; }
  .btn--xl  { font-size: 17px; padding: 20px 32px; border-radius: var(--radius-lg); }

  /* Variants */
  .btn--primary {
    background: var(--accent);
    --btn-bg: var(--accent);
    --btn-shadow: 0 8px 28px rgba(232, 90, 37, 0.38);
    --btn-shadow-hover: 0 14px 42px rgba(232, 90, 37, 0.52);
  }
  .btn--primary:hover {
    background: var(--accent-hover);
  }

  .btn--secondary {
    --btn-bg: var(--bg-surface);
    --btn-color: var(--text-primary);
    --btn-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    --btn-shadow-hover: 0 14px 36px rgba(0, 0, 0, 0.5);
    background: var(--bg-surface);
    border: 1px solid var(--border-medium);
  }

  .btn--whatsapp {
    --btn-bg: var(--whatsapp-green);
    --btn-shadow: 0 8px 24px rgba(37, 211, 102, 0.30);
    --btn-shadow-hover: 0 14px 36px rgba(37, 211, 102, 0.42);
    background: var(--whatsapp-green);
  }

  .btn--outline {
    --btn-bg: transparent;
    --btn-color: var(--accent);
    --btn-shadow: none;
    --btn-shadow-hover: 0 8px 24px rgba(232, 90, 37, 0.22);
    background: transparent;
    border: 1.5px solid var(--accent);
  }
  .btn--outline:hover {
    background: var(--accent);
    color: var(--text-white);
  }

  .btn--ghost {
    --btn-bg: transparent;
    --btn-color: var(--text-primary);
    --btn-shadow: none;
    --btn-shadow-hover: none;
    background: rgba(246, 248, 252, 0.05);
    border: 1.5px solid var(--border-medium);
    color: var(--text-primary);
  }
  .btn--ghost:hover {
    background: rgba(246, 248, 252, 0.08);
    border-color: var(--accent);
    color: var(--accent);
  }

  .btn--glass {
    --btn-bg: rgba(246, 248, 252, 0.06);
    --btn-color: var(--text-primary);
    --btn-shadow: inset 0 0 0 1px rgba(246, 248, 252, 0.14);
    --btn-shadow-hover: inset 0 0 0 1px rgba(232, 90, 37, 0.3), 0 8px 24px rgba(0,0,0,0.3);
    background: rgba(246, 248, 252, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(246, 248, 252, 0.14);
  }
  .btn--glass:hover {
    background: rgba(246, 248, 252, 0.1);
    border-color: rgba(232, 90, 37, 0.3);
  }
</style>
