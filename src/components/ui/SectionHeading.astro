---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
  variant?: 'light' | 'dark';
  highlight?: string;
}

const {
  label,
  title,
  subtitle,
  align = 'center',
  variant = 'light',
  highlight,
} = Astro.props;

// Render title, optionally highlighting a substring with accent gradient
const renderedTitle = highlight && title.includes(highlight)
  ? title.split(highlight).map((part, i, arr) =>
      i < arr.length - 1
        ? `${part}<span class="section-heading__accent">${highlight}</span>`
        : part
    ).join('')
  : title;
---

<div class:list={['section-heading', `section-heading--${align}`, `section-heading--${variant}`]}>
  {label && (
    <span class="eyebrow">
      <span class="eyebrow__dot"></span>
      {label}
    </span>
  )}
  <h2 class="section-heading__title" set:html={renderedTitle}></h2>
  {subtitle && <p class="section-heading__subtitle">{subtitle}</p>}
</div>

<style>
  .section-heading {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 760px;
  }
  .section-heading--center { align-items: center; text-align: center; margin: 0 auto; }
  .section-heading--left   { align-items: flex-start; text-align: left; }

  .section-heading__title {
    font-family: var(--font);
    font-size: clamp(28px, 4.5vw, 46px);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.1;
    letter-spacing: var(--tracking-tight);
  }
  .section-heading--dark .section-heading__title { color: var(--text-white); }

  .section-heading__subtitle {
    font-size: clamp(15px, 1.5vw, 18px);
    color: var(--text-secondary);
    line-height: 1.6;
    font-weight: 400;
    max-width: 620px;
  }
  .section-heading--dark .section-heading__subtitle { color: #94A3B8; }

  :global(.section-heading__accent) {
    background: var(--grad-text-accent);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    position: relative;
    white-space: nowrap;
  }
</style>
