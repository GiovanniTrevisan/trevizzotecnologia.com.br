---
interface Props {
  label?: string;
  title: string;
  align?: 'center' | 'left';
}

const { label, title, align = 'center' } = Astro.props;
---

<div class:list={['section-heading', `section-heading--${align}`]}>
  {label && <span class="section-heading__label">{label}</span>}
  <h2 class="section-heading__title">{title}</h2>
</div>

<style>
  .section-heading {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .section-heading--center {
    align-items: center;
    text-align: center;
  }
  .section-heading--left {
    align-items: flex-start;
    text-align: left;
  }
  .section-heading__label {
    font-family: var(--font);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .section-heading__title {
    font-family: var(--font);
    font-size: 22px;
    font-weight: 700;
    color: var(--text-white);
    line-height: 1.3;
    max-width: 700px;
  }
  @media (min-width: 1024px) {
    .section-heading__label { font-size: 13px; }
    .section-heading__title { font-size: 36px; }
  }
</style>
